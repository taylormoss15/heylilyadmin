// Hey Lily Admin — data model
// Covers everything GHL doesn't natively store: the accessibility audit trail,
// uptime incident history, managed-email seat tracking, and a log of writes
// back into GHL (custom fields / notes / workflow triggers).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres in all environments. DATABASE_URL is injected by Coolify (from
  // the Postgres resource) in production; for local dev, run the bundled
  // `docker compose -f docker-compose.dev.yml up -d` and use the DATABASE_URL
  // in .env.example. The models use plain String fields for enum-like values
  // (a portability choice from the SQLite era), so nothing else changes here.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite's Prisma connector doesn't support native enums, so the fields
// below that would otherwise be enums (Tier, ClientStatus, ScanStatus,
// EmailProvider, SeatStatus) are plain Strings, validated against the
// matching union types in lib/types.ts at the API boundary (zod schemas
// in the route handlers). If this moves to Postgres, these can become
// real `enum` blocks again — see lib/types.ts for the value sets.

// A sales prospect: an existing site we've run the compliance checker against
// to show how risky it is. Lives on the Prospecting page. Converting one
// creates a Client and marks the prospect CONVERTED (it falls off the list).
model Prospect {
  id               String   @id @default(cuid())
  url              String   @unique // normalized (lowercase host, no trailing slash) for dedup
  businessName     String? // best-guess from the page; editable
  industry         String? // manually enriched
  estimatedRevenue String? // manually enriched (free-form, e.g. "$1M–$5M")
  employees        String? // manually enriched (free-form, e.g. "11–50")
  phone            String?
  email            String?
  notes            String?

  scanStatus     String  @default("PENDING") // PENDING | COMPLETED | FAILED
  scanError      String?
  score          Float? // 0-100 accessibility score (higher = safer)
  violationCount Int     @default(0)
  seriousCount   Int     @default(0)
  passCount      Int     @default(0)
  violations     String? // JSON-encoded axe summary
  scannedAt      DateTime?

  // Site intelligence gathered in the same quick scan.
  platform           String? // detected builder/CMS (Wix, WordPress, GoDaddy, Squarespace…)
  builtBy            String? // "powered by / website by" credit found on the page
  professionalism    Int? // AI visual-quality rating, 1 (DIY) – 5 (polished custom)
  professionalismNote String? // one-line AI take on the design
  aeoScore           Int? // 0-100 on-page / AEO optimization score
  aeoChecks          String? // JSON array of individual on-page checks

  status            String  @default("PROSPECT") // PROSPECT | CONVERTED | DISMISSED
  convertedClientId String? // set when converted to a Client
  demoToken         String? // token of the latest generated demo, for quick linking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([score])
}

// A shareable sales demo generated for a prospect: their real site's "before"
// (screenshot + risk score + outcome-framed problems) next to an AI-built
// "after" redesign. Served publicly (no login) at /demo/[token] and as a
// print-friendly scorecard at /demo/[token]/report — the acquisition asset.
model Demo {
  id           String  @id @default(cuid())
  token        String  @unique
  prospectId   String?
  sourceUrl    String
  businessName String?

  // Before (their current site)
  beforeScore     Float?
  beforeViolations Int    @default(0)
  beforeSerious   Int     @default(0)
  beforeShot      String? // data: URL (JPEG) screenshot of the original site
  issues          String? // JSON array of outcome-framed problem statements

  // On-page / SEO snapshot of the current site (carried from the prospect scan)
  seoScore   Int? // 0-100 on-page/AEO score
  seoChecks  String? // JSON array of AEO checks (label, pass, detail)
  platform   String? // detected site builder, if any

  // After (the AI redesign)
  redesignHtml String? // finalized, compliance-checked HTML of the new site
  afterScore   Float?
  dryRun       Boolean @default(false) // true when built in mock mode (no AI key)

  status    String   @default("PENDING") // PENDING | READY | FAILED
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
}

model Client {
  id            String       @id @default(cuid())
  name          String
  domain        String? // primary site domain, used as scan/uptime target
  siteUrl       String? // full URL to scan/monitor if different from domain
  ghlLocationId String?      @unique // GHL sub-account ("location") id
  tier          String       @default("STARTER") // Tier: STARTER | PRO | PREMIUM
  status        String       @default("ACTIVE") // ClientStatus: ACTIVE | AT_RISK | CHURNED
  hasTrackers   Boolean      @default(false) // drives cookie-banner toggle in snapshot
  scanCadenceDays Int        @default(7) // weekly by default per spec

  // Business/ops details for troubleshooting — where things are hosted and
  // free-form internal notes. None of this is client-facing.
  hostingProvider String? // where the site is hosted (Coolify/Lightsail, GHL, Wix…)
  domainRegistrar String? // where the domain was bought (GoDaddy, Namecheap…)
  dnsProvider     String? // where DNS is managed (Cloudflare, registrar…)
  internalNotes   String? // free-form ops/troubleshooting notes

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accessibilityScans AccessibilityScan[]
  remediationNotes   RemediationNote[]
  uptimeMonitor      UptimeMonitor?
  uptimeIncidents    UptimeIncident[]
  emailSeats         EmailSeat[]
  ghlSyncLogs        GhlSyncLog[]
  sites              Site[]

  @@index([status])
  @@index([tier])
}

model AccessibilityScan {
  id              String     @id @default(cuid())
  clientId        String
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scannedAt       DateTime   @default(now())
  url             String
  tool            String     @default("axe-core")
  violationCount  Int        @default(0)
  seriousCount    Int        @default(0) // "serious"/"critical" impact violations
  passCount       Int        @default(0)
  incompleteCount Int        @default(0)
  score           Float? // 0-100 composite score, if computed
  violations      String // JSON-encoded axe-core violation summary
  status          String     @default("COMPLETED") // ScanStatus: COMPLETED | FAILED
  errorMessage    String?

  remediationNotes RemediationNote[]

  @@index([clientId, scannedAt])
}

model RemediationNote {
  id        String             @id @default(cuid())
  clientId  String
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scanId    String?
  scan      AccessibilityScan? @relation(fields: [scanId], references: [id], onDelete: SetNull)
  note      String
  createdBy String
  createdAt DateTime           @default(now())

  @@index([clientId, createdAt])
}

model UptimeMonitor {
  id                String   @id @default(cuid())
  clientId          String   @unique
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider          String // "uptimerobot" | "betterstack"
  externalMonitorId String? // id assigned by the external uptime tool
  url               String
  createdAt         DateTime @default(now())
}

model UptimeIncident {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider    String
  startedAt   DateTime
  resolvedAt  DateTime?
  reason      String?
  rawPayload  String? // JSON-encoded original webhook payload
  ghlNotified Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([clientId, startedAt])
}

model EmailSeat {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider        String // EmailProvider: GOOGLE_WORKSPACE | MICROSOFT_365
  seatEmail       String
  status          String    @default("ACTIVE") // SeatStatus: ACTIVE | SUSPENDED | DEPROVISIONED
  createdAt       DateTime  @default(now())
  deprovisionedAt DateTime?

  @@index([clientId])
}

// Audit trail of every write the backend makes into GHL (custom field
// updates, notes, workflow triggers) — useful for debugging sync issues.
model GhlSyncLog {
  id           String   @id @default(cuid())
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  action       String // e.g. "trigger_workflow", "update_custom_field", "add_note"
  payload      String? // JSON-encoded request payload
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([clientId, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// --- Website builder (Phase A) ---
// A Site belongs to a Client and holds shared theme + business data. Its
// Pages each store an IR (structured JSON section list) that the renderer
// turns into self-contained, compliance-baked-in HTML. See lib/site/*.
// theme / businessData / ir are JSON-encoded strings (SQLite has no JSON
// column); their shapes are defined and validated in lib/site/ir.ts.

model Site {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  status           String   @default("DRAFT") // DRAFT | PUBLISHED
  theme            String // JSON: Theme
  businessData     String // JSON: BusinessData
  showCookieBanner Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pages Page[]

  @@index([clientId])
}

model Page {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  path      String   @default("/")
  title     String
  ir        String // JSON: PageIR (ordered sections) — the structured/editable version
  customHtml String? // AI-generated bespoke HTML. When set, the page renders from
  //                    this (with compliance injected) instead of the IR. Clear it
  //                    to fall back to the structured renderer.
  isHome    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions       PageVersion[]
  publishRecords PublishRecord[]

  @@unique([siteId, path])
  @@index([siteId])
}

// Snapshot of a page's IR + rendered HTML on every edit — powers undo and
// a design audit trail.
model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  ir        String // JSON snapshot
  html      String // rendered snapshot
  createdBy String
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
}

model SiteAsset {
  id        String   @id @default(cuid())
  siteId    String
  kind      String // "image" | "font"
  cdnUrl    String
  alt       String?
  bytes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([siteId])
}

// Ties a published page back to its validation results (a11y score, size).
model PublishRecord {
  id          String    @id @default(cuid())
  pageId      String
  page        Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  target      String    @default("ghl")
  externalRef String?
  status      String // "VALIDATED" | "PUBLISHED" | "BLOCKED"
  a11yScore   Float?
  sizeBytes   Int       @default(0)
  publishedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([pageId, createdAt])
}
