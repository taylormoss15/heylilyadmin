# --- Website builder ---
# Public base URL where THIS admin app is deployed. Generated client sites
# embed the compliance badge script from here (must be absolute so it works
# when the page is hosted on GHL under the client's own domain).
ADMIN_BASE_URL=https://admin.heylily.ai

# --- Cloudflare R2 (site image hosting) ---
# S3-compatible bucket for images used on generated client sites. GHL
# requires absolute CDN URLs, so uploads live here. Leave unset to use the
# local-disk fallback (images served from /api/assets/*) — fine for dev,
# but set these in production. Create the API token in the R2 dashboard
# (Manage API Tokens) scoped to Object Read & Write on the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket — the bucket's r2.dev URL or a custom
# domain like https://cdn.heylily.ai. This is the prefix for image URLs.
R2_PUBLIC_BASE_URL=

# --- Anthropic API (AI site editor) ---
# Powers the natural-language site editor (Phase C). Read server-side only;
# never exposed to the browser. Leave unset to run the editor in mock mode.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
ANTHROPIC_MODEL=

# --- Accessibility scanner ---
# Optional: path to a pre-installed Chromium binary, if you don't want
# Playwright to manage its own browser download (e.g. a sandboxed CI/dev
# environment with one already provisioned).
PLAYWRIGHT_EXECUTABLE_PATH=

# --- Database ---
# SQLite by default (zero-config local dev). For production, point this at
# Postgres and change the provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# --- Admin auth ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Used only by `npm run db:seed` to create/update the first admin login.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- GoHighLevel (GHL) ---
# Private Integration token (or agency API key) scoped to the sub-accounts
# this backend manages. Without this set, GHL calls run in dry-run mode —
# everything else still works, writes just get logged instead of sent.
GHL_API_TOKEN=

# Inbound webhook URL for the GHL workflow that alerts the internal team on
# a "site is down" event (Workflows > your alert workflow > Inbound Webhook
# trigger). Internal-only per spec — no client-facing status page.
GHL_UPTIME_ALERT_WORKFLOW_WEBHOOK_URL=

# --- Uptime monitor webhook receiver ---
# Optional shared secret appended as ?secret=... to the webhook URL you
# configure in UptimeRobot / Better Stack, e.g.:
#   https://admin.example.com/api/webhooks/uptime?provider=uptimerobot&secret=...
UPTIME_WEBHOOK_SECRET=

# --- Cron ---
# Shared secret required in the X-Cron-Secret header when calling
# POST /api/cron/accessibility-scan from your scheduler.
CRON_SECRET=

# --- Google Workspace seat provisioning (optional) ---
# Service account JSON (as a single-line string) with domain-wide
# delegation for the admin.directory.user scope, plus the Workspace admin
# email to impersonate. Leave unset to run seat provisioning in dry-run
# mode (DB record created, no real Google Admin API call).
GOOGLE_WORKSPACE_SERVICE_ACCOUNT_JSON=
GOOGLE_WORKSPACE_ADMIN_EMAIL=

# --- Microsoft 365 seat provisioning (optional) ---
# App registration with Microsoft Graph User.ReadWrite.All application
# permission, client-credentials flow. Leave unset to run seat
# provisioning in dry-run mode.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
